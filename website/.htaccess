# Diffract marketing site — Hostinger shared (LiteSpeed) config.

# Never serve the Dodo secret, any .env, or a signup log, even if one ends up
# inside public_html (the real ones live ABOVE public_html and aren't web-served).
<FilesMatch "(^\.diffract-dodo\.env|\.env|\.log)$">
  Require all denied
</FilesMatch>

# Pretty URL: /api/checkout -> /api/checkout.php (bonus; signup.html already
# posts directly to /api/checkout.php so this is not load-bearing).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^api/checkout/?$ api/checkout.php [L]
  RewriteRule ^api/claim/?$ api/claim.php [L]
  # Pretty URL: /signup -> /signup.html (URL stays /signup).
  RewriteRule ^signup/?$ signup.html [L]
</IfModule>
